# Smart Campus — Incident Ticketing & Maintenance Module
# .gitignore

# ── Backend ──────────────────────────────────────────────────
backend/target/
backend/*.log
backend/uploads/
backend/.mvn/wrapper/maven-wrapper.jar
!backend/.mvn/wrapper/maven-wrapper.properties

# ── Frontend ─────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── IDE / OS ─────────────────────────────────────────────────
.idea/
*.iml
.vscode/
.DS_Store
Thumbs.db
*.swp

# ── Env / Secrets ─────────────────────────────────────────────
.env
.env.local
*.env

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
